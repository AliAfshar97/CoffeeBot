@model BaleManagerSystem.Models.ViewModels.PaymentReportViewModel

@{
    ViewData["Title"] = "گزارش سفارش‌ها";
}

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold">

                    <i class="bi bi-receipt-cutoff text-primary"></i>

                    گزارش سفارش‌ها

                </h2>

                <p class="text-muted mb-0">
                    مبلغی که هر نفر بابت سفارش‌هایش باید پرداخت کند.
                </p>

            </div>

        </div>

        <form asp-action="PaymentReport" method="get" class="row g-3 mb-4">

            <div class="col-md-4">

                <label class="form-label">از تاریخ</label>

                <input type="date"
                       name="fromDate"
                       value="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                       class="form-control" />

            </div>

            <div class="col-md-4">

                <label class="form-label">تا تاریخ</label>

                <input type="date"
                       name="toDate"
                       value="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                       class="form-control" />

            </div>

            <div class="col-md-4 d-flex align-items-end">

                <button type="submit" class="btn btn-primary btn-modern me-2">
                    <i class="bi bi-funnel"></i>
                    فیلتر
                </button>

                <a asp-action="PaymentReport" class="btn btn-outline-secondary btn-modern me-2">
                    پاک کردن
                </a>

                <a asp-action="ExportPaymentReport"
                   asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                   asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="btn btn-success btn-modern">
                    <i class="bi bi-file-earmark-excel"></i>
                    خروجی اکسل
                </a>

            </div>

        </form>

        <div class="row g-3 mb-4">

            <div class="col-md-4">

                <div class="p-3 bg-light rounded-4">

                    <div class="text-muted small">تعداد افراد</div>

                    <div class="fs-3 fw-bold">@Model.Summaries.Count</div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="p-3 bg-light rounded-4">

                    <div class="text-muted small">تعداد سفارش</div>

                    <div class="fs-3 fw-bold">@Model.TotalOrders</div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="p-3 bg-primary text-white rounded-4">

                    <div class="small opacity-75">جمع کل</div>

                    <div class="fs-3 fw-bold">@Model.GrandTotalToman.ToString("N0") تومان</div>

                </div>

            </div>

        </div>

        @foreach (var person in Model.Summaries)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-3">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <div>

                            <h5 class="fw-bold mb-1">@person.DisplayName</h5>

                            <div class="text-muted small">
                                شناسه چت: @person.ChatId |
                                تعداد سفارش: @person.OrderCount
                            </div>

                        </div>

                        <div class="text-end">

                            <div class="text-muted small">مبلغ قابل پرداخت</div>

                            <div class="fs-4 fw-bold text-primary">
                                @person.TotalToman.ToString("N0") تومان
                            </div>

                        </div>

                    </div>

                    <div class="table-responsive">

                        <table class="table table-sm align-middle mb-0">

                            <thead>

                                <tr>

                                    <th>نوشیدنی</th>

                                    <th>شات</th>

                                    <th>شکلات</th>

                                    <th>مبلغ</th>

                                    <th>تاریخ</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var order in person.Orders)
                                {
                                    <tr>

                                        <td>@PersianLabels.Drink(order.DrinkType)</td>

                                        <td>@order.ShotCount</td>

                                        <td>@PersianLabels.YesNo(order.WithChocolate)</td>

                                        <td>@order.PriceInToman.ToString("N0")</td>

                                        <td>@order.CreatedAt</td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>
        }

        @if (!Model.Summaries.Any())
        {
            <div class="alert alert-info mb-0">
                در بازه انتخاب‌شده سفارشی یافت نشد.
            </div>
        }

    </div>

</div>
