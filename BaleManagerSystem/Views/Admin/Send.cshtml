@model BaleManagerSystem.Models.ViewModels.BroadcastPageViewModel

@{
    ViewData["Title"] = "Broadcast";
}

<form method="post">

    <div class="row g-4">

        <!-- MESSAGE PANEL -->
        <div class="col-lg-5">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-4">

                    <h2 class="fw-bold mb-4">

                        <i class="bi bi-megaphone-fill text-primary"></i>
                        Broadcast Message

                    </h2>

                    <div class="mb-4">

                        <label class="form-label fw-semibold">

                            Message

                        </label>

                        <textarea asp-for="Message"
                                  class="form-control rounded-4"
                                  rows="10"
                                  placeholder="Write your message here...">
                    </textarea>

                    </div>


                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-4">

                            @ViewBag.Error

                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success rounded-4">

                            <div class="fw-bold mb-2">

                                Broadcast Completed

                            </div>

                            Successful Sends:
                            <strong>@ViewBag.Success</strong>

                            <br />

                            Failed Sends:
                            <strong>@ViewBag.Failed</strong>

                        </div>
                    }


                    <button type="submit"
                            class="btn btn-primary btn-lg w-100 rounded-4 shadow-sm">

                        <i class="bi bi-send-fill"></i>
                        Send Broadcast

                    </button>

                </div>

            </div>

        </div>


        <!-- CONTACTS -->
        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <div>

                            <h2 class="fw-bold">

                                <i class="bi bi-people-fill text-primary"></i>
                                Contacts

                            </h2>

                            <p class="text-muted mb-0">

                                Select users to receive message

                            </p>

                        </div>

                        <span class="badge bg-primary rounded-pill px-3 py-2">

                            @Model.Users.Count Users

                        </span>

                    </div>


                    <!-- SEARCH -->
                    <div class="mb-4">

                        <input type="text"
                               id="userSearch"
                               class="form-control rounded-4"
                               placeholder="Search phone number..." />

                    </div>


                    <!-- SELECT ALL -->
                    <div class="mb-4">

                        <div class="form-check">

                            <input class="form-check-input"
                                   type="checkbox"
                                   id="selectAll" />

                            <label class="form-check-label fw-semibold"
                                   for="selectAll">

                                Select All Users

                            </label>

                        </div>

                    </div>


                    <!-- USER LIST -->
                    <div style="max-height:550px;overflow-y:auto;">

                        @foreach (var user in Model.Users)
                        {
                            <div class="user-item border rounded-4 p-3 mb-3 shadow-sm">

                                <div class="form-check d-flex align-items-center">

                                    <input class="form-check-input user-checkbox me-3"
                                           type="checkbox"
                                           name="SelectedPhones"
                                           value="@user.PhoneNumber" />

                                    <div>

                                        <div class="fw-bold">

                                            @user.PhoneNumber

                                        </div>

                                        <div class="fw-bold">

                                            @user.Username

                                        </div>

                                        <small class="text-muted">

                                            Registered:
                                            @user.FirstSeen.ToString("yyyy/MM/dd")

                                        </small>

                                    </div>

                                </div>

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

</form>


@section Scripts {

    <script>

        // SEARCH CONTACTS
        document.getElementById("userSearch")
            .addEventListener("keyup", function () {

            let filter =
                this.value.toLowerCase();

            let users =
                document.querySelectorAll(".user-item");

            users.forEach(user => {

                let text =
                    user.innerText.toLowerCase();

                if (text.includes(filter)) {
                    user.style.display = "";
                }
                else {
                    user.style.display = "none";
                }

            });

        });


        // SELECT ALL USERS
        document.getElementById("selectAll")
            .addEventListener("change", function () {

            let checked = this.checked;

            document.querySelectorAll(".user-checkbox")
                .forEach(cb => {

                cb.checked = checked;

            });

        });

    </script>

}