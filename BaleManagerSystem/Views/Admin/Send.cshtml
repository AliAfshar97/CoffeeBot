@model BaleManagerSystem.Models.ViewModels.BroadcastPageViewModel

@{
    ViewData["Title"] = "ارسال پیام";
}

<form method="post"
      enctype="multipart/form-data">

    <div class="row g-4">

        <!-- MESSAGE PANEL -->
        <div class="col-lg-5">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-4">

                    <h2 class="fw-bold mb-3">

                        <i class="bi bi-megaphone-fill text-primary"></i>
                        ارسال پیام

                    </h2>

                    <p class="text-muted mb-4">

                        پیام متنی و فایل پیوست را
                        برای کاربران انتخاب‌شده ارسال کنید.

                    </p>

                    <!-- MESSAGE -->
                    <div class="mb-4">

                        <label class="form-label fw-semibold">

                            متن پیام

                        </label>

                        <textarea asp-for="Message"
                                  class="form-control rounded-4"
                                  rows="8"
                                  placeholder="پیام خود را اینجا بنویسید...">
                        </textarea>

                    </div>

                    <!-- FILE -->
                    <div class="mb-4">

                        <label class="form-label fw-semibold">

                            فایل پیوست

                        </label>

                        <input asp-for="Attachment"
                               type="file"
                               class="form-control rounded-4" />

                        <div class="form-text">

                            PDF, Word, Excel, Images, ZIP ...

                        </div>

                    </div>

                    <div id="accountStatementPanel"
                         class="mb-4 p-3 border rounded-4 bg-light"
                         style="display:none;">

                        <label class="d-flex align-items-start gap-2 mb-3 user-select-label">

                            <input asp-for="IncludeAccountStatement"
                                   class="form-check-input flex-shrink-0 mt-1"
                                   type="checkbox"
                                   id="includeAccountStatement" />

                            <span>
                                <span class="fw-semibold d-block">پیوست صورت‌حساب</span>
                                <small class="text-muted">
                                    مانده کل حساب + لیست سفارش‌های بازه زمانی + مهلت پرداخت
                                </small>
                            </span>

                        </label>

                        <div id="accountStatementFields">

                            <div class="row g-3">

                                <div class="col-md-4">

                                    <label asp-for="StatementFromDate" class="form-label fw-semibold">
                                        از تاریخ
                                    </label>

                                    <input asp-for="StatementFromDate"
                                           type="date"
                                           class="form-control rounded-4" />

                                </div>

                                <div class="col-md-4">

                                    <label asp-for="StatementToDate" class="form-label fw-semibold">
                                        تا تاریخ
                                    </label>

                                    <input asp-for="StatementToDate"
                                           type="date"
                                           class="form-control rounded-4" />

                                </div>

                                <div class="col-md-4">

                                    <label asp-for="PaymentDueDate" class="form-label fw-semibold">
                                        مهلت پرداخت
                                    </label>

                                    <input asp-for="PaymentDueDate"
                                           type="date"
                                           class="form-control rounded-4" />

                                </div>

                            </div>

                        </div>

                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-4">

                            @ViewBag.Error

                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success rounded-4">

                            <h6 class="fw-bold">

                                ارسال انجام شد

                            </h6>

                            <hr />

                            ارسال موفق:
                            <strong>@ViewBag.Success</strong>

                            <br />

                            ارسال ناموفق:
                            <strong>@ViewBag.Failed</strong>

                        </div>
                    }

                    <button type="submit"
                            class="btn btn-primary btn-lg w-100 rounded-4 shadow-sm">

                        <i class="bi bi-send-fill"></i>

                        ارسال پیام

                    </button>

                </div>

            </div>

        </div>

        <!-- CONTACTS -->
        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <div>

                            <h2 class="fw-bold">

                                <i class="bi bi-people-fill text-primary"></i>
                                مخاطبان

                            </h2>

                            <p class="text-muted mb-0">

                                گیرندگان را انتخاب کنید

                            </p>

                        </div>

                        <span class="badge bg-primary rounded-pill px-3 py-2">

                            @(Model.PhoneUsers.Count +
                                                        Model.TelegramUsers.Count)

                            کاربر

                        </span>

                    </div>

                    <!-- TABS -->
                    <ul class="nav nav-pills mb-4">

                        <li class="nav-item">

                            <button type="button"
                                    class="nav-link active"
                                    id="phoneTab">

                                📱 کاربران تلفنی

                            </button>

                        </li>

                        <li class="nav-item ms-2">

                            <button type="button"
                                    class="nav-link"
                                    id="telegramTab">

                                🤖 کاربران حساب رایان

                            </button>

                        </li>

                    </ul>

                    <input asp-for="RecipientType"
                           type="hidden"
                           id="recipientType" />

                    <!-- SEARCH -->
                    <div class="mb-3">

                        <input type="text"
                               id="userSearch"
                               class="form-control rounded-4"
                               placeholder="جستجوی کاربر..." />

                    </div>

                    <!-- SELECTED COUNT -->
                    <div class="alert alert-light border rounded-4">

                        کاربران انتخاب‌شده:

                        <strong id="selectedCount">

                            0

                        </strong>

                    </div>

                    <!-- SELECT ALL -->
                    <div class="mb-3">

                        <label class="d-flex align-items-center gap-2 mb-0 user-select-label">

                            <input type="checkbox"
                                   class="form-check-input flex-shrink-0"
                                   id="selectAll" />

                            <span>انتخاب همه</span>

                        </label>

                    </div>

                    <div style="max-height:550px;overflow-y:auto;">

                        <!-- PHONE USERS -->
                        <div id="phoneUsers">

                            @foreach (var user in Model.PhoneUsers)
                            {
                                <label class="user-item border rounded-4 p-3 mb-3 shadow-sm d-flex align-items-center gap-3 w-100 user-select-label">

                                    <input class="form-check-input flex-shrink-0 user-checkbox"
                                           type="checkbox"
                                           name="SelectedPhones"
                                           value="@user.PhoneNumber" />

                                    <div class="flex-grow-1">

                                        <div class="fw-bold">

                                            @user.PhoneNumber

                                        </div>

                                        <div class="text-muted">

                                            @user.Username

                                        </div>

                                    </div>

                                </label>
                            }

                        </div>

                        <!-- TELEGRAM USERS -->
                        <div id="telegramUsers"
                             style="display:none;">

                            @foreach (var user in Model.TelegramUsers)
                            {
                                <label class="user-item border rounded-4 p-3 mb-3 shadow-sm d-flex align-items-center gap-3 w-100 user-select-label">

                                    <input class="form-check-input flex-shrink-0 user-checkbox"
                                           type="checkbox"
                                           name="SelectedChatIds"
                                           value="@user.ChatId" />

                                    <div class="flex-grow-1">

                                        <div class="fw-bold">

                                            @user.Username

                                        </div>

                                        <div class="text-primary">

                                            شناسه چت:
                                            @user.ChatId

                                        </div>

                                        <small class="text-muted">

                                            تاریخ ثبت:
                                            @user.FirstSeen.ToString("yyyy/MM/dd")

                                        </small>

                                    </div>

                                </label>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</form>

@section Scripts
{
    <script>

        const phoneTab =
            document.getElementById("phoneTab");

        const telegramTab =
            document.getElementById("telegramTab");

        const phoneUsers =
            document.getElementById("phoneUsers");

        const telegramUsers =
            document.getElementById("telegramUsers");

        const recipientType =
            document.getElementById("recipientType");

        const accountStatementPanel =
            document.getElementById("accountStatementPanel");

        const includeAccountStatement =
            document.getElementById("includeAccountStatement");

        const accountStatementFields =
            document.getElementById("accountStatementFields");

        recipientType.value = "Phone";

        function toggleAccountStatementPanel()
        {
            const isTelegram = recipientType.value === "Telegram";
            accountStatementPanel.style.display = isTelegram ? "" : "none";

            if (!isTelegram)
            {
                includeAccountStatement.checked = false;
            }

            toggleAccountStatementFields();
        }

        function toggleAccountStatementFields()
        {
            accountStatementFields.style.display =
                includeAccountStatement.checked ? "" : "none";
        }

        phoneTab.addEventListener("click", () => {

            phoneTab.classList.add("active");
            telegramTab.classList.remove("active");

            phoneUsers.style.display = "";
            telegramUsers.style.display = "none";

            recipientType.value = "Phone";
            document.getElementById("selectAll").checked = false;
            toggleAccountStatementPanel();
            updateSelectedCount();
        });

        telegramTab.addEventListener("click", () => {

            telegramTab.classList.add("active");
            phoneTab.classList.remove("active");

            telegramUsers.style.display = "";
            phoneUsers.style.display = "none";

            recipientType.value = "Telegram";
            document.getElementById("selectAll").checked = false;
            toggleAccountStatementPanel();
            updateSelectedCount();
        });

        includeAccountStatement.addEventListener("change", toggleAccountStatementFields);

        toggleAccountStatementPanel();

        document.getElementById("userSearch")
            .addEventListener("keyup", function () {

                let filter =
                    this.value.toLowerCase();

                document
                    .querySelectorAll(".user-item")
                    .forEach(item => {

                        let text =
                            item.innerText.toLowerCase();

                        item.style.display =
                            text.includes(filter)
                                ? ""
                                : "none";
                    });
            });

        document.getElementById("selectAll")
            .addEventListener("change", function () {

                let checked =
                    this.checked;

                getVisibleCheckboxes()
                    .forEach(cb => {

                        cb.checked = checked;
                    });

                updateSelectedCount();
            });

        function getVisibleCheckboxes()
        {
            const activeList =
                recipientType.value === "Telegram"
                    ? telegramUsers
                    : phoneUsers;

            return activeList.querySelectorAll(".user-checkbox");
        }

        function updateSelectedCount()
        {
            const count =
                getVisibleCheckboxes().length > 0
                    ? Array.from(getVisibleCheckboxes())
                        .filter(cb => cb.checked)
                        .length
                    : 0;

            document.getElementById(
                "selectedCount")
                .innerText = count;
        }

        document.addEventListener("change",
            function (e)
            {
                if (e.target.classList.contains("user-checkbox"))
                {
                    updateSelectedCount();
                }
            });

        document.querySelector("form").addEventListener("submit", function () {
            const hiddenList =
                recipientType.value === "Telegram"
                    ? phoneUsers
                    : telegramUsers;

            hiddenList.querySelectorAll(".user-checkbox").forEach(cb => {
                cb.disabled = true;
            });
        });

    </script>
}