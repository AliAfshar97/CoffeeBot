@model List<BaleManagerSystem.Models.PaymentReceipt>

@{
    ViewData["Title"] = "رسیدهای پرداخت";
    var processed = ViewBag.ProcessedReceipts as List<BaleManagerSystem.Models.PaymentReceipt> ?? new();
}

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold">

                    <i class="bi bi-image text-primary"></i>

                    رسیدهای پرداخت

                </h2>

                <p class="text-muted mb-0">
                    رسیدهای ارسالی کاربران را بررسی کنید و بستانکاری ثبت کنید.
                </p>

            </div>

        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <h4 class="fw-bold mb-3">در انتظار بررسی (@Model.Count)</h4>

        @if (!Model.Any())
        {
            <div class="alert alert-info">رسید در انتظاری وجود ندارد.</div>
        }

        @foreach (var receipt in Model)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">

                <div class="card-body">

                    <div class="row g-4">

                        <div class="col-md-4">

                            @if (!string.IsNullOrEmpty(receipt.LocalFilePath))
                            {
                                <img src="@receipt.LocalFilePath"
                                     class="img-fluid rounded-4 border"
                                     alt="رسید @receipt.Id" />
                            }
                            else
                            {
                                <div class="p-4 bg-light rounded-4 text-muted">
                                    تصویر به صورت محلی ذخیره نشده است.
                                </div>
                            }

                        </div>

                        <div class="col-md-8">

                            <h5 class="fw-bold">@receipt.DisplayName</h5>

                            <div class="text-muted mb-3">
                                رسید #@receipt.Id |
                                شناسه چت: @receipt.ChatId |
                                @receipt.CreatedAt
                            </div>

                            @if (!string.IsNullOrWhiteSpace(receipt.UserCaption))
                            {
                                <p><strong>توضیح کاربر:</strong> @receipt.UserCaption</p>
                            }

                            <form asp-action="ApproveReceipt" method="post" class="row g-3 mb-3">

                                <input type="hidden" name="ReceiptId" value="@receipt.Id" />

                                <div class="col-md-4">

                                    <label class="form-label">مبلغ بستانکاری (تومان)</label>

                                    <input type="number"
                                           name="CreditAmount"
                                           min="1"
                                           class="form-control"
                                           required />

                                </div>

                                <div class="col-md-5">

                                    <label class="form-label">یادداشت مدیر</label>

                                    <input type="text"
                                           name="AdminNote"
                                           class="form-control"
                                           placeholder="یادداشت اختیاری" />

                                </div>

                                <div class="col-md-3 d-flex align-items-end">

                                    <button type="submit" class="btn btn-success btn-modern w-100">
                                        تایید و شارژ
                                    </button>

                                </div>

                            </form>

                            <form asp-action="RejectReceipt" method="post" class="d-flex gap-2">

                                <input type="hidden" name="receiptId" value="@receipt.Id" />

                                <input type="text"
                                       name="adminNote"
                                       class="form-control"
                                       placeholder="دلیل رد (اختیاری)" />

                                <button type="submit" class="btn btn-outline-danger btn-modern">
                                    رد
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        }

        @if (processed.Any())
        {
            <h4 class="fw-bold mb-3 mt-5">بررسی‌شده</h4>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>شناسه</th>

                            <th>نام</th>

                            <th>وضعیت</th>

                            <th>بستانکاری</th>

                            <th>یادداشت</th>

                            <th>تاریخ</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var receipt in processed)
                        {
                            <tr>

                                <td>@receipt.Id</td>

                                <td>@receipt.DisplayName</td>

                                <td>
                                    <span class="badge @(receipt.Status == "Approved" ? "bg-success" : "bg-secondary")">
                                        @PersianLabels.ReceiptStatus(receipt.Status)
                                    </span>
                                </td>

                                <td>@(receipt.CreditAmount?.ToString("N0") ?? "-")</td>

                                <td>@receipt.AdminNote</td>

                                <td>@receipt.ProcessedAt</td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>
