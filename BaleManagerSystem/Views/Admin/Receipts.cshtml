@model List<BaleManagerSystem.Models.PaymentReceipt>

@{
    ViewData["Title"] = "Payment Receipts";
    var processed = ViewBag.ProcessedReceipts as List<BaleManagerSystem.Models.PaymentReceipt> ?? new();
}

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold">

                    <i class="bi bi-image text-primary"></i>

                    Payment Receipts

                </h2>

                <p class="text-muted mb-0">
                    Review receipt photos from users and charge credit to their account.
                </p>

            </div>

        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <h4 class="fw-bold mb-3">Pending (@Model.Count)</h4>

        @if (!Model.Any())
        {
            <div class="alert alert-info">No pending receipts.</div>
        }

        @foreach (var receipt in Model)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">

                <div class="card-body">

                    <div class="row g-4">

                        <div class="col-md-4">

                            @if (!string.IsNullOrEmpty(receipt.LocalFilePath))
                            {
                                <img src="@receipt.LocalFilePath"
                                     class="img-fluid rounded-4 border"
                                     alt="Receipt #@receipt.Id" />
                            }
                            else
                            {
                                <div class="p-4 bg-light rounded-4 text-muted">
                                    Photo not saved locally.
                                </div>
                            }

                        </div>

                        <div class="col-md-8">

                            <h5 class="fw-bold">@receipt.DisplayName</h5>

                            <div class="text-muted mb-3">
                                Receipt #@receipt.Id |
                                Chat ID: @receipt.ChatId |
                                @receipt.CreatedAt
                            </div>

                            @if (!string.IsNullOrWhiteSpace(receipt.UserCaption))
                            {
                                <p><strong>User caption:</strong> @receipt.UserCaption</p>
                            }

                            <form asp-action="ApproveReceipt" method="post" class="row g-3 mb-3">

                                <input type="hidden" name="ReceiptId" value="@receipt.Id" />

                                <div class="col-md-4">

                                    <label class="form-label">Credit Amount (Toman)</label>

                                    <input type="number"
                                           name="CreditAmount"
                                           min="1"
                                           class="form-control"
                                           required />

                                </div>

                                <div class="col-md-5">

                                    <label class="form-label">Admin Note</label>

                                    <input type="text"
                                           name="AdminNote"
                                           class="form-control"
                                           placeholder="Optional note" />

                                </div>

                                <div class="col-md-3 d-flex align-items-end">

                                    <button type="submit" class="btn btn-success btn-modern w-100">
                                        Approve & Charge
                                    </button>

                                </div>

                            </form>

                            <form asp-action="RejectReceipt" method="post" class="d-flex gap-2">

                                <input type="hidden" name="receiptId" value="@receipt.Id" />

                                <input type="text"
                                       name="adminNote"
                                       class="form-control"
                                       placeholder="Reject reason (optional)" />

                                <button type="submit" class="btn btn-outline-danger btn-modern">
                                    Reject
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        }

        @if (processed.Any())
        {
            <h4 class="fw-bold mb-3 mt-5">Processed</h4>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>ID</th>

                            <th>Name</th>

                            <th>Status</th>

                            <th>Credit</th>

                            <th>Note</th>

                            <th>Date</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var receipt in processed)
                        {
                            <tr>

                                <td>@receipt.Id</td>

                                <td>@receipt.DisplayName</td>

                                <td>
                                    @if (receipt.Status == "Approved")
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Rejected</span>
                                    }
                                </td>

                                <td>@(receipt.CreditAmount?.ToString("N0") ?? "-")</td>

                                <td>@receipt.AdminNote</td>

                                <td>@receipt.ProcessedAt</td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>
