@model BaleManagerSystem.Models.ViewModels.AccountsPageViewModel
@using BaleManagerSystem.Models.ViewModels

@{
    ViewData["Title"] = "مانده حساب‌ها";
    var users = ViewBag.Users as List<UserChatIdViewModel> ?? new List<UserChatIdViewModel>();
}

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold">

                    <i class="bi bi-wallet2 text-primary"></i>

                    مانده حساب‌ها

                </h2>

                <p class="text-muted mb-0">
                    بدهکار = سفارش‌ها | بستانکار = پرداخت‌ها | مانده = بدهکار − بستانکار
                </p>

            </div>

        </div>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form asp-action="Accounts" method="get" class="row g-3 mb-4">

            <div class="col-md-3">

                <label class="form-label">از تاریخ</label>

                <input type="date"
                       name="fromDate"
                       value="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                       class="form-control" />

            </div>

            <div class="col-md-3">

                <label class="form-label">تا تاریخ</label>

                <input type="date"
                       name="toDate"
                       value="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                       class="form-control" />

            </div>

            <div class="col-md-6 d-flex align-items-end">

                <button type="submit" class="btn btn-primary btn-modern me-2">
                    فیلتر
                </button>

                <a asp-action="Accounts" class="btn btn-outline-secondary btn-modern me-2">
                    پاک کردن
                </a>

                <a asp-action="ExportAccounts"
                   asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                   asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="btn btn-success btn-modern">
                    <i class="bi bi-file-earmark-excel"></i>
                    خروجی اکسل
                </a>

            </div>

        </form>

        <div class="row g-3 mb-4">

            <div class="col-md-4">

                <div class="p-3 bg-light rounded-4">

                    <div class="text-muted small">جمع بدهکار</div>

                    <div class="fs-4 fw-bold text-danger">
                        @Model.GrandTotalDebit.ToString("N0") تومان
                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="p-3 bg-light rounded-4">

                    <div class="text-muted small">جمع بستانکار</div>

                    <div class="fs-4 fw-bold text-success">
                        @Model.GrandTotalCredit.ToString("N0") تومان
                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="p-3 bg-primary text-white rounded-4">

                    <div class="small opacity-75">جمع مانده</div>

                    <div class="fs-4 fw-bold">
                        @Model.GrandTotalRemaining.ToString("N0") تومان
                    </div>

                </div>

            </div>

        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">

            <div class="card-body">

                <h5 class="fw-bold mb-3">افزودن بستانکاری دستی</h5>

                <form asp-action="AddCredit" method="post" class="row g-3">

                    <div class="col-md-4">

                        <label class="form-label">کاربر</label>

                        <select name="ChatId" class="form-select" required id="creditUserSelect">

                            <option value="">انتخاب کاربر...</option>

                            @foreach (var user in users.Where(u => !string.IsNullOrWhiteSpace(u.DisplayName)))
                            {
                                <option value="@user.ChatId" data-name="@user.DisplayName">
                                    @user.DisplayName (@user.ChatId)
                                </option>
                            }

                        </select>

                        <input type="hidden" name="DisplayName" id="creditDisplayName" />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label">مبلغ (تومان)</label>

                        <input type="number"
                               name="Amount"
                               min="1"
                               class="form-control"
                               required />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label">توضیحات</label>

                        <input type="text"
                               name="Description"
                               class="form-control"
                               placeholder="پرداخت نقدی" />

                    </div>

                    <div class="col-md-2 d-flex align-items-end">

                        <button type="submit" class="btn btn-success btn-modern w-100">
                            ثبت بستانکاری
                        </button>

                    </div>

                </form>

            </div>

        </div>

        @foreach (var person in Model.Balances)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-3">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">

                        <div>

                            <h5 class="fw-bold mb-1">@person.DisplayName</h5>

                            <div class="text-muted small">شناسه چت: @person.ChatId</div>

                        </div>

                        <div class="d-flex gap-4 text-end">

                            <div>

                                <div class="text-muted small">بدهکار</div>

                                <div class="fw-bold text-danger">
                                    @person.TotalDebit.ToString("N0")
                                </div>

                            </div>

                            <div>

                                <div class="text-muted small">بستانکار</div>

                                <div class="fw-bold text-success">
                                    @person.TotalCredit.ToString("N0")
                                </div>

                            </div>

                            <div>

                                <div class="text-muted small">مانده</div>

                                <div class="fw-bold text-primary fs-5">
                                    @person.Remaining.ToString("N0") تومان
                                </div>

                            </div>

                        </div>

                    </div>

                    @if (person.Transactions.Any())
                    {
                        <div class="table-responsive">

                            <table class="table table-sm align-middle mb-0">

                                <thead>

                                    <tr>

                                        <th>نوع</th>

                                        <th>مبلغ</th>

                                        <th>توضیحات</th>

                                        <th>ثبت توسط</th>

                                        <th>تاریخ</th>

                                    </tr>

                                </thead>

                                <tbody>

                                    @foreach (var tx in person.Transactions)
                                    {
                                        <tr>

                                            <td>
                                                @if (tx.TransactionType == "Debit")
                                                {
                                                    <span class="badge bg-danger">بدهکار</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">بستانکار</span>
                                                }
                                            </td>

                                            <td>@tx.Amount.ToString("N0")</td>

                                            <td>@tx.Description</td>

                                            <td>@tx.CreatedBy</td>

                                            <td>@tx.CreatedAt</td>

                                        </tr>
                                    }

                                </tbody>

                            </table>

                        </div>
                    }

                </div>

            </div>
        }

        @if (!Model.Balances.Any())
        {
            <div class="alert alert-info mb-0">
                در بازه انتخاب‌شده تراکنشی یافت نشد.
            </div>
        }

    </div>

</div>

@section Scripts
{
    <script>
        document.getElementById("creditUserSelect")?.addEventListener("change", function () {
            const selected = this.options[this.selectedIndex];
            document.getElementById("creditDisplayName").value = selected.dataset.name || "";
        });
    </script>
}
