@{
    ViewData["Title"] = "داشبورد";
}

<style>

    .dashboard-card {
        border-radius: 24px;
        padding: 25px;
        color: white;
        min-height: 150px;
        box-shadow: 0 12px 30px rgba(0,0,0,.12);
        transition: all .3s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

    .users-card {
        background: linear-gradient(135deg,#2563eb,#3b82f6);
    }

    .consultation-card {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
    }

    .card-title-small {
        font-size: 14px;
        letter-spacing: 1px;
        opacity: .9;
    }

    .card-number {
        font-size: 48px;
        font-weight: 800;
        margin-top: 10px;
        line-height: 1;
    }

    .card-icon {
        font-size: 60px;
        opacity: .25;
    }

</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold mb-1">
            داشبورد
        </h2>

        <p class="text-muted mb-0">
            مدیریت ربات سفارش قهوه
        </p>

    </div>

</div>

<div class="row g-4 mb-5">

    <div class="col-lg-6 col-md-6">

        <div class="dashboard-card users-card">

            <div class="d-flex justify-content-between">

                <div>

                    <div class="card-title-small">
                        کاربران ربات
                    </div>

                    <div class="card-number">
                        @ViewBag.TotalUsers
                    </div>

                </div>

                <div class="card-icon">

                    <i class="bi bi-people-fill"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-6 col-md-6">

        <div class="dashboard-card consultation-card">

            <div class="d-flex justify-content-between">

                <div>

                    <div class="card-title-small">
                        سفارش‌های قهوه
                    </div>

                    <div class="card-number">
                        @ViewBag.TotalOrders
                    </div>

                </div>

                <div class="card-icon">

                    <i class="bi bi-cup-hot-fill"></i>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-5">

        <h3 class="fw-bold mb-3">

            به پنل مدیریت ربات قهوه خوش آمدید

        </h3>

        <p class="text-muted fs-5">

            سفارش‌های همکاران را ببینید، حساب‌ها را مدیریت کنید،
            رسیدهای پرداخت را بررسی کنید و گزارش‌ها را خروجی بگیرید.

        </p>

    </div>

</div>
