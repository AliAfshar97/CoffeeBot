@{
    ViewData["Title"] = "Dashboard";
}

<style>

    .dashboard-card {
        border-radius: 24px;
        padding: 25px;
        color: white;
        min-height: 150px;
        box-shadow: 0 12px 30px rgba(0,0,0,.12);
        transition: all .3s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

    .users-card {
        background: linear-gradient(135deg,#2563eb,#3b82f6);
    }

    .success-card {
        background: linear-gradient(135deg,#059669,#10b981);
    }

    .failed-card {
        background: linear-gradient(135deg,#dc2626,#ef4444);
    }

    .consultation-card {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
    }

    .card-title-small {
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: .9;
    }

    .card-number {
        font-size: 48px;
        font-weight: 800;
        margin-top: 10px;
        line-height: 1;
    }

    .card-icon {
        font-size: 60px;
        opacity: .25;
    }

</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold mb-1">
            Dashboard
        </h2>

        <p class="text-muted mb-0">
            Bale Broadcast Management System
        </p>

    </div>

</div>

<div class="row g-4 mb-5">

    <!-- TOTAL USERS -->
    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card users-card">

            <div class="d-flex justify-content-between">

                <div>

                    <div class="card-title-small">
                        Total Users
                    </div>

                    <div class="card-number">
                        @ViewBag.TotalUsers
                    </div>

                </div>

                <div class="card-icon">

                    <i class="bi bi-people-fill"></i>

                </div>

            </div>

        </div>

    </div>

    <!-- SUCCESS -->
    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card success-card">

            <div class="d-flex justify-content-between">

                <div>

                    <div class="card-title-small">
                        Successful Sends
                    </div>

                    <div class="card-number">
                        @ViewBag.Success
                    </div>

                </div>

                <div class="card-icon">

                    <i class="bi bi-check-circle-fill"></i>

                </div>

            </div>

        </div>

    </div>

    <!-- FAILED -->
    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card failed-card">

            <div class="d-flex justify-content-between">

                <div>

                    <div class="card-title-small">
                        Failed Sends
                    </div>

                    <div class="card-number">
                        @ViewBag.Failed
                    </div>

                </div>

                <div class="card-icon">

                    <i class="bi bi-x-circle-fill"></i>

                </div>

            </div>

        </div>

    </div>

    <!-- CONSULTATIONS -->
    <div class="col-lg-3 col-md-6">

        <div class="dashboard-card consultation-card">

            <div class="d-flex justify-content-between">

                <div>

                    <div class="card-title-small">
                        Consultations
                    </div>

                    <div class="card-number">
                        @ViewBag.TotalConsultations
                    </div>

                </div>

                <div class="card-icon">

                    <i class="bi bi-chat-left-text-fill"></i>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-5">

        <h3 class="fw-bold mb-3">

            Welcome to Bale Broadcast Manager

        </h3>

        <p class="text-muted fs-5">

            Manage users, send broadcast messages,
            monitor delivery statistics and review
            consultation requests from one central dashboard.

        </p>

    </div>

</div>