@model List<BaleManagerSystem.Models.Consultation>

@{
    ViewData["Title"] = "Consultations";
}

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-body p-4">

        <div class="d-flex justify-content-between mb-4">

            <div>

                <h2 class="fw-bold">

                    <i class="bi bi-chat-square-text-fill text-primary"></i>

                    Consultations

                </h2>

                <p class="text-muted">

                    Total Requests:
                    <strong>@Model.Count</strong>

                </p>

            </div>

        </div>

        <div class="mb-3">

            <input type="text"
                   id="searchBox"
                   class="form-control"
                   placeholder="Search..." />

        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle"
                   id="consultationTable">

                <thead class="table-light">

                    <tr>

                        <th>Chat Id</th>

                        <th>Full Name</th>

                        <th>Phone Number</th>

                        <th>Company</th>

                        <th>Category</th>

                        <th>Brief</th>

                        <th>Date</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.ChatId</td>

                            <td>@item.FullName</td>

                            <td>@item.PhoneNumber</td>

                            <td>@item.Company</td>

                            <td>
                                <span class="badge bg-primary">
                                    @item.Category
                                </span>
                            </td>

                            <td style="max-width:300px;">
                                @item.ShortBrief
                            </td>

                            <td>
                                @item.CreatedAt
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        document.getElementById("searchBox")
            .addEventListener("keyup", function () {

                let filter =
                    this.value.toLowerCase();

                let rows =
                    document.querySelectorAll(
                        "#consultationTable tbody tr");

                rows.forEach(row => {

                    let text =
                        row.innerText.toLowerCase();

                    row.style.display =
                        text.includes(filter)
                            ? ""
                            : "none";
                });

            });

    </script>
}